# ==========================================================
# Python Virtual Environments
# ==========================================================
.venv/
venv/
env/

# ==========================================================
# Python Cache
# ==========================================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================================
# Distribution / Build
# ==========================================================
build/
dist/
*.egg-info/

# ==========================================================
# IDE
# ==========================================================
.vscode/
.idea/

# ==========================================================
# OS Files
# ==========================================================
.DS_Store
Thumbs.db

# ==========================================================
# Environment Variables
# ==========================================================
# Exact-name matches only (never a broad `.env*` glob) so .env.example
# — committed, secret-free, and required for the Docker Compose workflow
# (see docs/environment-configuration.md) — is never accidentally ignored.
.env
.env.local
.env.*.local

# ==========================================================
# Secrets
# ==========================================================
secrets/
*.ovpn

# ==========================================================
# Logs
# ==========================================================
*.log

# ==========================================================
# Testing
# ==========================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ==========================================================
# Jupyter
# ==========================================================
.ipynb_checkpoints/

# ==========================================================
# Runtime Reports
# ==========================================================
run_reports/
*.json
*.jsonl.bak

# ==========================================================
# APEX Knowledge Database
# ==========================================================

# ------------------------------------------------------------------
# RAW PAYLOAD SOURCES (ignore)
# ------------------------------------------------------------------
Knowledge/payload_db/SecLists/
Knowledge/payload_db/PayloadsAllTheThings/
Knowledge/payload_db/GTFOBins/
Knowledge/payload_db/LOLBAS/

# ------------------------------------------------------------------
# RAW INTELLIGENCE DATASETS (ignore)
# ------------------------------------------------------------------
Knowledge/intel_db/cve/
Knowledge/intel_db/cwe/
Knowledge/intel_db/capec/
Knowledge/intel_db/attack/

# ------------------------------------------------------------------
# Downloaded archives
# ------------------------------------------------------------------
Knowledge/**/*.zip
Knowledge/**/*.tar
Knowledge/**/*.tar.gz
Knowledge/**/*.7z
Knowledge/**/*.gz

# ------------------------------------------------------------------
# Ignore caches/indexes generated locally
# ------------------------------------------------------------------
Knowledge/**/.cache/
Knowledge/**/cache/
Knowledge/**/*.faiss
Knowledge/**/*.idx
Knowledge/**/*.index
Knowledge/**/*.sqlite
Knowledge/**/*.db
Knowledge/**/*.tmp

# ------------------------------------------------------------------
# KEEP compiled runtime artifacts
# ------------------------------------------------------------------
!Knowledge/**/compiled/
!Knowledge/**/compiled/**

# ------------------------------------------------------------------
# KEEP policy database
# ------------------------------------------------------------------
!Knowledge/policy_db/
!Knowledge/policy_db/**

# ------------------------------------------------------------------
# KEEP documentation
# ------------------------------------------------------------------
!Knowledge/**/*.md
!Knowledge/**/*.txt