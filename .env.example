# .env.example
# Template for the APEX/Kali environment file — copy to .env, fill in the required token, never commit the real .env.
#
# Usage:
#   cp .env.example .env
#   # edit .env: generate and set APEX_TOOL_SERVICE_TOKEN (see below)
#   APEX_TOOL_SERVICE_TOKEN=$(python -c "import secrets; print(secrets.token_urlsafe(32))") \
#     docker compose up --build --abort-on-container-exit
#
# .env is gitignored and dockerignored — see docs/environment-configuration.md
# "Git and Docker ignore behavior" for the exact rules. This file
# (.env.example) IS committed and contains no usable secret and no target.
#
# Full documentation of every variable below, precedence rules (CLI flag >
# environment variable > built-in default), and every entry point that
# consumes them: docs/environment-configuration.md.

# =============================================================================
# APEX execution
# =============================================================================

# Safe default. Real command execution ALWAYS additionally requires the
# explicit --no-dry-run CLI flag on apex_host.main / apex_host.eval.run_htb_local
# — setting APEX_DRY_RUN=false here, by itself, can never enable live
# execution (CLAUDE.md §13.5). Leave this at true, or unset (true is the
# built-in default either way).
APEX_DRY_RUN=true

# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL. -v/--verbose on the CLI
# always overrides this and means DEBUG. Leave unset to use each entry
# point's own pre-existing default (INFO for apex_host.main, WARNING for
# apex_host.eval.run_htb_local).
# APEX_LOG_LEVEL=INFO

# Maximum engagement turns. Built-in default: 20.
# APEX_MAX_TURNS=20

# =============================================================================
# Target and runtime files
# =============================================================================

# No default target is provided, and none should ever be added here.
# Leave blank (or omit the line) to require an explicit --target on the
# command line — that is the safe, expected state for this template.
# An explicit --target CLI flag always overrides this variable; a blank
# value counts as unset either way.
APEX_TARGET=

# Root of the compiled knowledge directory. Only meaningful for
# apex_host.main / apex_host.eval.run_htb_local — the APEX container image
# already bakes in the compiled knowledge subset at this exact path
# (docker/apex/Dockerfile, docs/apex-container.md §9), so this default only
# needs to be changed if you mount a different knowledge directory yourself.
# APEX_KNOWLEDGE_ROOT=/app/knowledge

# Explicit path to the policy YAML. Optional — apex_host falls back to
# discovery via APEX_KNOWLEDGE_ROOT, then a conservative built-in default,
# when this is unset (apex_host/policy/policy_loader.py).
# APEX_POLICY_FILE=/app/knowledge/policy_db/compiled/hackthebox_lab.yaml

# Phase 4 (post-live-test debugging) — durable directory for the
# persistent, incremental knowledge-initialization cache
# (apex_host/knowledge/init_cache.py; docs/knowledge-initialization.md).
# The compose.yaml `apex` service already sets this to the mounted
# apex-knowledge-cache named volume by default — this line only needs
# uncommenting for a non-Compose (bare `python -m apex_host...`) run
# against a durable path of your own choosing. Unset (the built-in
# default) means NO cross-run persistence: every startup re-stages
# compiled knowledge from scratch (still fast — see the docs above — just
# not skipped entirely across container restarts).
# APEX_KNOWLEDGE_CACHE_PATH=/app/knowledge_cache
# APEX_KNOWLEDGE_CACHE_LOCK_TIMEOUT_SECONDS=30

# apex_host.eval.run_htb_local only (apex_host.main has no report-export
# flags at all). Equivalent to --export-json / --export-graph. Unset by
# default — no report is written unless one of these (or the matching CLI
# flag) is set.
# APEX_REPORT_PATH=/app/run_reports/run.json
# APEX_GRAPH_PATH=/app/run_reports/run_ekg.json

# =============================================================================
# Tool backend (apex_host -> apex_tool_service client selection)
# =============================================================================

# One of: dry-run, local, remote. "remote" is what the Compose smoke-test
# workflow (compose.yaml) uses to reach the "kali" service; "local" is what
# apex_host has always defaulted to outside of Compose. Ignored entirely
# whenever dry-run is in effect — dry-run always wins (see APEX_DRY_RUN
# above and docs/remote-tool-backend.md §4).
APEX_TOOL_BACKEND=remote

# Base URL of the apex_tool_service instance. http://kali:8080 is the
# Compose-internal service-name address (compose.yaml, apex-internal
# network) — correct for `docker compose up`/`run`. Change this only if
# you are running apex_tool_service somewhere else (e.g. directly on the
# host during local development).
APEX_TOOL_SERVICE_URL=http://kali:8080

# REQUIRED, and MUST be blank in this template. Generate a real, disposable
# value yourself — never reuse a value found in documentation or examples:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# There is deliberately no --tool-service-token CLI flag anywhere in this
# codebase (CLI arguments are visible in shell history and `ps` output) —
# this environment variable is the only way to supply it. Both the "apex"
# and "kali" Compose services require this value (compose.yaml's
# ${APEX_TOOL_SERVICE_TOKEN:?...} fails fast if it is unset or blank).
APEX_TOOL_SERVICE_TOKEN=

# Overall client-side request timeout budget, in seconds, for the remote
# tool backend. Built-in default: 120.0.
# APEX_TOOL_SERVICE_TIMEOUT_SECONDS=120

# =============================================================================
# LLM configuration (Phase 5 — native OpenAI/Anthropic/OpenRouter providers)
# =============================================================================
#
# Full architecture, configuration matrix, and error taxonomy:
# docs/llm-providers.md. Summary of the model this section configures:
#
#   provider=openai      -> native OpenAI adapter     -> api.openai.com by
#                            default -> OPENAI_API_KEY -> model string passed
#                            to OpenAI EXACTLY as given (e.g. "gpt-4o")
#   provider=anthropic   -> native Anthropic adapter   -> api.anthropic.com
#                            by default -> ANTHROPIC_API_KEY -> model string
#                            passed to Anthropic EXACTLY as given
#                            (e.g. "claude-sonnet-4-5-20250929")
#   provider=openrouter  -> OpenRouter adapter (optional, its own identity,
#                            never provider=openai + a custom base URL)
#                            -> openrouter.ai by default -> OPENROUTER_API_KEY
#                            -> router-style "vendor/model" IDs are only
#                            meaningful here, never for openai/anthropic
#
# There is deliberately NO provider-neutral default model anywhere in this
# codebase — APEX_USE_LLM=true requires an explicit APEX_LLM_PROVIDER AND an
# explicit APEX_LLM_MODEL for that provider, or engagement start-up/readiness
# fails fast with a clear "provider_model_mismatch"-style error rather than
# guessing. Model IDs are NEVER rewritten, prefixed, or stripped by APEX —
# whatever you put in APEX_LLM_MODEL is sent to the provider byte-for-byte.

# Fully deterministic, no API calls — the safe default and the default in
# this template. Do not flip this to true unless you also set the LLM
# provider, model, and that provider's own API key below.
APEX_USE_LLM=false

# One of: fake, openai, anthropic, openrouter (case-insensitive; normalized
# internally). "fake" (the default) means FakeModelRouter — no network, no
# API key needed, exactly matching APEX_USE_LLM=false above.
APEX_LLM_PROVIDER=fake

# Model identifier for the selected provider. Unused while the provider
# above is "fake". Use a NATIVE model ID for openai/anthropic — never a
# router-style "vendor/model" string for those two (that shape is only
# valid for the openrouter provider, and is rejected as a
# provider_model_mismatch for openai/anthropic). Verify the exact model ID
# against your own provider account/docs before using it — APEX does not
# ship or validate an exhaustive model allowlist. Examples (placeholders —
# verify before use; provider -> model):
#   openai      -> <VALID_NATIVE_OPENAI_MODEL_ID>
#   anthropic   -> <VALID_NATIVE_ANTHROPIC_MODEL_ID>
#   openrouter  -> <VALID_OPENROUTER_ROUTE_ID>
APEX_LLM_MODEL=

# Read directly by apex_host.llm.providers.openai.OpenAIProvider — never by
# apex_host/config_env.py's generic merge (CLI args are visible in shell
# history and `ps`; environment variables set via `export` are not — same
# rationale as APEX_TOOL_SERVICE_TOKEN above). Required only when the LLM
# layer is enabled with the openai provider selected. Never used for any
# other provider — APEX never falls back to this key for Anthropic or
# OpenRouter.
OPENAI_API_KEY=

# Read directly by apex_host.llm.providers.anthropic.AnthropicProvider.
# Required only when the LLM layer is enabled with the anthropic provider
# selected.
ANTHROPIC_API_KEY=

# Read directly by apex_host.llm.providers.openrouter.OpenRouterProvider.
# Required only when the LLM layer is enabled with the openrouter provider
# selected.
OPENROUTER_API_KEY=

# Optional, provider-specific base URL overrides — each applies ONLY to its
# own provider; APEX never carries one provider's URL into another
# provider's client. Leave all three blank to use each provider's own
# official SDK default endpoint (api.openai.com / api.anthropic.com /
# openrouter.ai). Setting APEX_LLM_OPENAI_BASE_URL to an OpenRouter-shaped
# URL while APEX_LLM_PROVIDER=openai is rejected as a provider_model_mismatch
# — use APEX_LLM_PROVIDER=openrouter instead (see docs/llm-providers.md
# "Migration from the old mixed OpenAI+OpenRouter configuration").
# APEX_LLM_OPENAI_BASE_URL=
# APEX_LLM_ANTHROPIC_BASE_URL=
# APEX_LLM_OPENROUTER_BASE_URL=

# =============================================================================
# Tool-service server configuration (apex_tool_service — the "kali" Compose
# service). Read directly by apex_tool_service/settings.py; independent of
# every variable above. Values shown here (commented out) are the real,
# implemented ServiceSettings defaults — uncomment only to override them.
# =============================================================================

# Never 0.0.0.0 by apex_tool_service's own library default (localhost-only
# unless explicitly opted in) — docker/kali/Dockerfile already bakes in
# 0.0.0.0 so the container is reachable on apex-internal; this only needs
# uncommenting if you want to override that baked-in value via Compose.
# APEX_TOOL_SERVICE_HOST=0.0.0.0
# APEX_TOOL_SERVICE_PORT=8080

# Used when a request omits its own timeout_seconds. Real default: 30.
# APEX_TOOL_SERVICE_DEFAULT_TIMEOUT_SECONDS=30

# Ceiling for an explicit per-request timeout_seconds. Real default: 120.
# APEX_TOOL_SERVICE_MAX_TIMEOUT_SECONDS=120

# Max arguments list length per request. Real default: 32.
# APEX_TOOL_SERVICE_MAX_ARGUMENTS=32

# Max characters per individual argument. Real default: 512.
# APEX_TOOL_SERVICE_MAX_ARGUMENT_LENGTH=4096

# Max stdin payload size in bytes. Real default: 65536.
# APEX_TOOL_SERVICE_MAX_STDIN_BYTES=65536

# stdout/stderr truncation ceilings in bytes. Real default: 1048576 each.
# APEX_TOOL_SERVICE_MAX_STDOUT_BYTES=1048576
# APEX_TOOL_SERVICE_MAX_STDERR_BYTES=1048576

# Phase 22 — the dedicated POST /v1/bounded-file-read operation's own,
# narrower limits. Deliberately separate from the generic-tool limits
# above: this operation is a structurally different, more restrictive
# capability with its own hard ceilings (a caller-requested value is
# always clamped to min(requested, this ceiling), never the other way
# around) and its own target-authorization/basename allowlists.
#
# Bounded-read output size ceiling in bytes. Real default: 4096.
# APEX_TOOL_SERVICE_BOUNDED_READ_MAX_BYTES=4096
#
# Bounded-read timeout ceiling in seconds. Real default: 10.0.
# APEX_TOOL_SERVICE_BOUNDED_READ_TIMEOUT=10
#
# Comma-separated list of approved candidate-file basenames — the ONLY
# filenames the bounded-read operation will ever read, regardless of
# directory. Real default: user.txt. Do not widen this to arbitrary
# filenames or system paths (e.g. /etc/passwd) unless explicitly required
# and authorized for a specific, narrow testing purpose.
# APEX_TOOL_SERVICE_ALLOWED_FLAG_BASENAMES=user.txt
#
# Comma-separated list of CIDR ranges the bounded-read operation will
# accept a "target" within — an independent, service-side authorization
# check (defense in depth on top of apex_host's own policy gate). Real
# default: 10.129.0.0/16 (the standard HTB lab network range — mirrors
# ApexConfig.htb_route_cidr's own established default). Never a single
# hardcoded machine IP; always operator-overridable.
# APEX_TOOL_SERVICE_AUTHORIZED_CIDRS=10.129.0.0/16

# =============================================================================
# HTB VPN integration (Infra Phase 10) — used only by the "htb" Compose
# profile (docker/vpn/, compose.htb.yaml). The default, non-htb Compose
# workflow (docker compose up --build) never reads any variable in this
# section and remains completely VPN-independent and target-free.
# =============================================================================

# REQUIRED for the htb profile only, and MUST be blank in this template.
# Absolute or relative-to-repo-root path to your own, personally-downloaded
# HTB Machines .ovpn profile. Store the real file under the gitignored
# secrets/ directory (e.g. secrets/htb.ovpn) — NEVER commit a .ovpn file.
# See docs/htb-vpn-manual-validation.md for the full walkthrough. Blank
# here means: "htb" Compose profile services fail fast with a clear error
# if started (compose.htb.yaml's ${APEX_HTB_OVPN_PATH:?...} interpolation)
# — the default, non-htb workflow is entirely unaffected either way.
APEX_HTB_OVPN_PATH=

# The private route APEX/the VPN container expect once the tunnel is up.
# HTB machine labs commonly use 10.129.0.0/16 — this is the real, safe
# default both docker/vpn/Dockerfile and apex_host/config.py already use;
# override only if your specific HTB profile/region documents a different
# range (docs/htb-vpn-container.md §10 "Route readiness").
APEX_HTB_ROUTE_CIDR=10.129.0.0/16

# Base URL of the VPN container's own readiness HTTP server (never
# apex_tool_service's port 8080 — this is the VPN container's separate,
# first-party readiness endpoint, docker/vpn/readiness_server.py). Only
# meaningful when the "htb" Compose profile is active; compose.htb.yaml
# sets this automatically to http://vpn:8090 — override only if you run
# the VPN readiness server somewhere else.
# APEX_VPN_SERVICE_URL=http://vpn:8090

# Bounded timeout, in seconds, for the VPN readiness GET /health call.
# Built-in default: 10.0.
# APEX_VPN_HEALTH_TIMEOUT_SECONDS=10
